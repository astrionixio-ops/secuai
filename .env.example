APP_NAME="SecuAI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:5173
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database (MySQL on the IONOS VPS) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=secuai
DB_USERNAME=secuai
DB_PASSWORD=

# --- Cache / Queue / Sessions ---
# VPS with Redis: use 'redis' for cache + queue, 'database' for sessions (so login
# state survives a Redis flush). No Redis? Change all three to 'database'.
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# --- JWT Auth (for the React SPA) ---
# Generate with: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# --- Sanctum (cookie-based; alternative to JWT) ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000
SESSION_DOMAIN=localhost

# --- Mail (SMTP) ---
# If your domain is on Hostinger and you use Hostinger Email, the host below works.
# Alternatives: Resend, SES, Postmark, Mailgun — all common for transactional mail.
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/oauth/google/callback"

# --- File storage (S3-compatible; falls back to local) ---
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Field-level encryption for cloud_credentials/integrations secrets ---
# Generate with: php -r "echo base64_encode(random_bytes(32)).PHP_EOL;"
SECRETS_ENCRYPTION_KEY=

# --- Real-time (provider-agnostic) ---
# Options: 'pusher', 'reverb', 'ably', 'log' (dev), 'null' (disabled)
BROADCAST_CONNECTION=log

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

ABLY_KEY=

# --- AI (OpenAI-compatible) ---
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o-mini

# --- Paddle billing ---
PADDLE_ENV=sandbox
PADDLE_SANDBOX_API_KEY=
PADDLE_LIVE_API_KEY=
PADDLE_SANDBOX_WEBHOOK_SECRET=
PADDLE_LIVE_WEBHOOK_SECRET=

# --- Feature flags ---
DEMO_MODE_ENABLED=true
SIGNUP_REQUIRES_INVITE=false
